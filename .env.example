# WhiteBIT MCP Server — environment configuration
# Copy this file to .env and set values as needed.
#
# Credentials can be supplied two ways:
#
#   HTTP transport  — pass as request headers (configured in .mcp.json):
#                       X-WB-Api-Key: <your api key>
#                       X-WB-Secret-Key: <your secret key>
#
#   stdio transport — set env vars below (used by `uvx whitebit-mcp` / setup_mcp.py):
#                       WHITEBIT_API_KEY=...
#                       WHITEBIT_SECRET_KEY=...

# WhiteBIT API base URL. Override for testnet or custom deployments.
WHITEBIT_BASE_URL=https://whitebit.com

# Credentials for stdio transport (uvx / whitebit-mcp-setup).
# WHITEBIT_API_KEY=
# WHITEBIT_SECRET_KEY=
