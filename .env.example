# WhiteBit MCP Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# Environment: testnet | production
# ============================================

# Production (for real trading)
WHITEBIT_BASE_URL=https://whitebit.com

# ============================================
# API Keys (OPTIONAL - for server-side fallback)
# ============================================
# Get keys from: https://whitebit.com/settings/api
# Required permissions: Read balance, Collateral trading, Read order history

WB_API_KEY_PUBLIC=
WB_API_KEY_PRIVATE=

# ============================================
# API Settings
# ============================================
WB_API_TIMEOUT=10.0
WB_API_MAX_RETRIES=3

# ============================================
# Logging
# ============================================
# Format: console (development) | json (production)
WB_LOG_FORMAT=console
# Level: debug | info | warn | error
WB_LOG_LEVEL=info

# ============================================
# Cache
# ============================================
WB_CACHE_ENABLED=true
WB_CACHE_TTL_TICKER=15
WB_CACHE_TTL_ORDERBOOK=15
WB_CACHE_TTL_TRADES=15
WB_CACHE_TTL_MARKET_INFO=300
WB_CACHE_TTL_ASSET_STATUS=300
WB_CACHE_TTL_FEES=3600
WB_CACHE_TTL_SERVER_TIME=5
WB_CACHE_TTL_FUTURES=60
WB_CACHE_TTL_MINING_POOL=300
